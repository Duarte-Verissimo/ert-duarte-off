@startuml
left to right direction
skinparam packageStyle rectangle

actor "Security Officer" as SO
actor "Transition Manager" as TM
actor "Active Directory" as AD <<Sistema Externo>>

rectangle "AMS Intake Platform (Intake & Discovery)" {
  usecase "UC-01: Autenticar utilizador" as UC1
  usecase "UC-02: Preencher formulário de Intake" as UC2
  usecase "UC-03: Anexar evidência de DR" as UC3
  usecase "UC-04: Aprovar formulário de Intake" as UC4
  usecase "UC-05: Reabrir Intake aprovado" as UC5
  usecase "UC-06: Sobrescrever dados aprovados" as UC6
}

SO --> UC1
TM --> UC1
AD --> UC1

TM --> UC2
SO --> UC2
TM --> UC3
SO --> UC3

TM --> UC4
SO --> UC4
TM --> UC5
SO --> UC5
SO --> UC6
@enduml
